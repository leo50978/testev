rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function validDiscussionMedia() {
      return request.resource != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType != null
        && (
          request.resource.contentType.matches("image/.*")
          || request.resource.contentType.matches("video/.*")
        );
    }

    function validDiscussionWrite() {
      return request.resource == null || validDiscussionMedia();
    }

    function signedIn() {
      return request.auth != null;
    }

    function isFinanceAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.financeAdmin == true
          || (
            request.auth.token.email != null
            && request.auth.token.email == "leovitch2004@gmail.com"
          )
        );
    }

    match /chat-media/channel/{allPaths=**} {
      allow read: if true;
      allow write: if isFinanceAdmin() && validDiscussionWrite();
    }

    match /chat-media/support/{threadId}/{allPaths=**} {
      allow read: if isFinanceAdmin()
        || (signedIn() && threadId == ("user_" + request.auth.uid));
      allow write: if (isFinanceAdmin()
        || (signedIn() && threadId == ("user_" + request.auth.uid)))
        && validDiscussionWrite();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
